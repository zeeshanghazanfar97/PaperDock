[Unit]
Description=PaperDock Scanner Proxy
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=paperdock
Group=paperdock
WorkingDirectory=/opt/paperdock/proxy
EnvironmentFile=/opt/paperdock/proxy/.env
ExecStart=/usr/bin/npm run start
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
